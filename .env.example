# ─────────────────────────────────────────────────────────────
#  Discus Fish — CLIENT environment (front-end, Vite)
#  Only PUBLIC values here. Vite exposes every VITE_* var to the
#  browser, so never put secrets in this file. Copy to .env.
# ─────────────────────────────────────────────────────────────

# Stripe publishable key (Developers > API keys). Public by design.
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Base URL of the Express back-end.
VITE_API_URL=http://localhost:3000

# Supabase project URL + publishable (anon) key. Public by design — RLS protects data.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxx
